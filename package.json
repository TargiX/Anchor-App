{
  "name": "anchor",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check:node": "node scripts/check-node-version.mjs",
    "check": "npm run check:node && npm run typecheck && npm run lint && npm run test && npm run build",
    "check:native": "npm run check && npm run build:native",
    "check:desktop": "npm run build:native && npm --prefix electron run check:node && npm --prefix electron run build",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:native": "cross-env BUILD_TARGET=native next build",
    "cap:sync": "npm run build:native && cap sync",
    "desktop:dev": "npm run cap:sync && cd electron && npm run electron:start",
    "desktop:pack": "npm run cap:sync && cd electron && npm run electron:pack",
    "desktop:make": "npm run cap:sync && cd electron && npm run electron:make",
    "mobile:add:ios": "npm run build:native && cap add ios",
    "mobile:add:android": "npm run build:native && cap add android",
    "mobile:open:ios": "cap open ios",
    "mobile:open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}

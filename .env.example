# Supabase — copy to .env.local and fill in from your project's Connect/API page.
# Production should set these so accounts and journal sync work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback only. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — copy to .env.local and fill in from your project's Connect/API page.
# Production should set these so accounts and journal sync work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback only. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel Cron Jobs sends this as an Authorization bearer token.
# Set a random 16+ character value in the Vercel project environment.
CRON_SECRET=

# Optional: Sentry error monitoring. Without these the SDK stays inert (no-op),
# so local dev, previews, and forks without a Sentry project send nothing.
# Create a project at https://sentry.io and copy the DSN from Project Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed to upload source maps in CI (keep real values secret, never commit).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
